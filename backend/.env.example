# Nyx AI Backend 配置

# 应用配置
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production

# 数据库
# 本地开发（SQLite）
# DATABASE_URL=sqlite:///./instance/nyx_ai.db
#
# 生产环境（Supabase PostgreSQL）
# 在 Supabase 控制台 → Settings → Database → Connection string → URI 复制
# 注意：使用 Transaction pooler 地址（端口 6543），并在末尾加 ?sslmode=require
DATABASE_URL=sqlite:///./instance/nyx_ai.db

# JWT配置
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS配置 (前端开发服务器地址)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Fish Audio API (TTS)
FISH_AUDIO_API_KEY=your-fish-audio-api-key

# Z-Image API (文生图)
ZIMAGE_API_KEY=your-zimage-api-key

# LLM API配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# 腾讯云 COS 对象存储（留空则使用本地存储）
# 用于存储文生图图片（cache/images/）和 TTS 音频（cache/tts/）
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_REGION=ap-guangzhou
COS_BUCKET=your-bucket-name-appid
# 可选：自定义 CDN/加速域名，留空则用 COS 默认域名
COS_CDN_DOMAIN=
