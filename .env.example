# NyxAI 生产环境配置示例
# 复制此文件为 .env 并填入真实值

# ============================================
# 数据库配置
# ============================================
# PostgreSQL 连接字符串（生产环境）
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://nyx:changeme@postgres:5432/nyx_ai

# SQLite 连接字符串（开发环境）
# DATABASE_URL=sqlite:///./instance/nyx_ai.db

# PostgreSQL 密码（用于 docker-compose）
POSTGRES_PASSWORD=changeme

# ============================================
# Redis 配置
# ============================================
# Redis 连接字符串（用于限流、缓存、Token 黑名单）
# 格式: redis://主机:端口/数据库号
REDIS_URL=redis://redis:6379/0

# ============================================
# 应用安全配置
# ============================================
# JWT 密钥（生产环境必须修改！）
SECRET_KEY=your-super-secret-key-change-this-in-production

# 调试模式（生产环境必须为 false）
DEBUG=false

# 应用名称
APP_NAME=Nyx AI API

# ============================================
# 外部 API 配置
# ============================================
# OpenRouter API Key（用于 LLM 调用）
OPENROUTER_API_KEY=sk-or-v1-...

# Z-Image API Key（用于文生图）
ZIMAGE_API_KEY=...

# Fish Audio API Key（用于 TTS 语音合成）
FISH_AUDIO_API_KEY=...

# OpenAI API Key（备用 LLM）
OPENAI_API_KEY=sk-...

# ============================================
# Telegram Bot 配置
# ============================================
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ============================================
# CORS 配置
# ============================================
# 允许的前端地址（JSON 数组格式）
CORS_ORIGINS=["https://your-domain.com", "https://www.your-domain.com"]

# ============================================
# 可选配置
# ============================================
# 系统角色默认声音 ID（Fish Audio）
SYSTEM_ROLE_VOICE_ID=5c09bfed66ce4a968c3022d6f85c8e07

# API 前缀
API_PREFIX=/api
